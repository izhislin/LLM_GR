# Gravitel CRM API (исходящие запросы к crm.aicall.ru)
GRAVITEL_API_KEY=your-crm-api-key-here

# Gravitel Webhook (входящие от облачной АТС)
GRAVITEL_WEBHOOK_KEY=your-webhook-key-here

# Web UI basic auth
WEB_USERNAME=admin
WEB_PASSWORD=change-me

# HuggingFace token (для GigaAM/pyannote)
HF_TOKEN=hf_xxx
